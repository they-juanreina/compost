{
  "name": "@they-juanreina/compost-cli",
  "version": "0.1.2",
  "description": "Compost CLI engine. Subcommand router, JSON-out, harness loop runner.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "bin": {
    "compost": "./bin/compost.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "transcriber",
    "package.json"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-schemas.mjs",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "prepack": "node scripts/copy-transcriber.mjs",
    "pretest": "node scripts/generate-schemas.mjs",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@they-juanreina/compost-evals": "workspace:*",
    "@they-juanreina/compost-provenance": "workspace:*",
    "@they-juanreina/compost-retrieval": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "tsx": "^4.19.0"
  }
}
