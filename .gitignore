*.swo

# Node
node_modules/
.pnpm-store/
.npm/
.yarn/
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# plugin/dist IS committed — it's the install payload. Claude Code's
# `/plugin install` copies files without running a build, so the MCP server
# JS the manifest points at must already be present. A CI consistency check
# (rebuild → git diff) guards against drift. The plugin is pure JS (only the
# MCP SDK); no native deps land here.
!plugin/dist/
!plugin/dist/**

# Generated build artifact: regenerated by cli's prebuild/pretest hooks from
# schema/*.json. Committing it caused stale-content drift on schema-touching
# merges (every PR that edited a schema had to recommit it). Every build path
# — CI and local — runs the generator first, so it never needs to be tracked.
cli/src/lib/schemas.generated.ts

# Generated build artifact: the Python transcriber source bundled into the cli
# tarball by `prepack` (copy-transcriber.mjs) so global installs transcribe
# natively (#206). Materialized only at pack/publish time from the canonical
# repo-root transcriber/, so it never shadows the real source in dev.
cli/transcriber/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env
.env.local
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Compost per-seed machine state. Gitignored by design — but NOT all disposable:
# .compost/events.sqlite is canonical, append-only provenance (not rebuildable)
# and .compost/AGENTS.md is hand-authored. Preserve/move a seed by copying the
# whole folder (incl. .compost/) or `compost backup`; don't rely on VCS for it.
.compost/
Seeds/

# Logs, locks, secrets
*.log
*.pid
*.seed
*.pid.lock
secrets/
secrets.env
.envrc
