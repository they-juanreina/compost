# Generated build artifact: regenerated by cli's prebuild/pretest hooks from
# schema/*.json. Committing it caused stale-content drift on schema-touching
# merges (every PR that edited a schema had to recommit it). Every build path
# — CI and local — runs the generator first, so it never needs to be tracked.
cli/src/lib/schemas.generated.ts

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env
.env.local
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Compost runtime state (per-seed; never committed)
.compost/
Seeds/

# Logs, locks, secrets
*.log
*.pid
*.seed
*.pid.lock
secrets/
.envrc
